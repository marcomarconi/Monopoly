contracts_to_wide <- function(all_contracts) {
all_contracts %>%
transmute(
Date,
rank,
C  = Last,
dC = dLast,
rC = ret,
prevC = prev,
name = contract_name
) %>%
pivot_wider(
names_from = rank,
values_from = c(C, dC, rC, prevC, name),
names_sep = ""
)
}
contracts_to_wide <- function(all_contracts) {
all_contracts %>%
transmute(
Date,
rank,
C  = Last,
dC = dLast,
rC = ret,
prevC = prev,
name = contract_name
) %>%
pivot_wider(
names_from = rank,
values_from = c(C, dC, rC, prevC, name),
names_sep = ""
) %>% arrange(Date)
}
